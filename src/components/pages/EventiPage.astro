---
import { EVENTS } from '../../data';
import Arrow from '../Arrow.astro';
import Pattern from '../Pattern.astro';
const tones = ['scallop', 'checker', 'bars', 'diamond'];
---
<main>
  <section class="section" style="background:var(--ink-800);padding-top:clamp(56px, 7vw, 96px);padding-bottom:clamp(56px, 7vw, 96px)">
    <div class="container">
      <div style="max-width:760px">
        <div class="eyebrow" style="color:var(--gold-500);margin-bottom:18px">Eventi</div>
        <h1 class="display" style="font-size:clamp(28px, 4.4vw, 54px);margin:0;font-weight:300">Formazione e dibattito,<br />sul territorio.</h1>
        <p style="margin-top:26px;font-size:clamp(15px, 1.3vw, 17px);line-height:1.7;opacity:0.86;max-width:640px;text-wrap:pretty">
          Lo Studio promuove e partecipa a momenti di approfondimento e confronto su temi di stretta attualità giuridica: dalla compliance aziendale alle nuove frontiere della sostenibilità, dal diritto tributario alla responsabilità degli enti.
        </p>
      </div>
    </div>
  </section>

  <section class="section" style="background:var(--ink-900);padding-top:clamp(48px, 6vw, 80px);padding-bottom:clamp(48px, 6vw, 80px)">
    <div class="container">
      <div style="display:flex;flex-direction:column;gap:clamp(20px, 2.5vw, 32px)">
        {EVENTS.map((ev, idx) => (
          <article class="evt-row">
            <div style="position:relative;overflow:hidden;min-height:280px">
              <Pattern tone={tones[(idx + 1) % tones.length]} />
              <div style="position:absolute;inset:0;display:flex;flex-direction:column;justify-content:flex-end;padding:clamp(24px, 3vw, 36px);background:linear-gradient(180deg, transparent 30%, rgba(29,47,46,0.6) 100%)">
                <div class="label-track" style="font-size:11px;color:var(--cream);text-shadow:0 1px 8px rgba(0,0,0,0.5)">Evento 0{idx + 1}</div>
                <div style="font-family:'Cormorant Garamond',serif;font-style:italic;font-size:clamp(38px, 5vw, 60px);color:var(--cream);line-height:1;margin-top:8px;text-shadow:0 2px 16px rgba(0,0,0,0.5)">{ev.dateShort}</div>
              </div>
            </div>
            <div style="padding:clamp(28px, 3vw, 44px);display:flex;flex-direction:column;justify-content:space-between">
              <div>
                <div style="display:flex;align-items:center;gap:14px;flex-wrap:wrap">
                  <span style="background:var(--ink-800);color:var(--cream);padding:6px 12px;font-size:10px;letter-spacing:0.2em;text-transform:uppercase;font-weight:500">{ev.kind}</span>
                  <span style="font-size:12px;letter-spacing:0.16em;text-transform:uppercase;color:var(--ink-700)">{ev.date}</span>
                </div>
                <h2 class="display" style="margin:18px 0 14px;font-size:clamp(20px, 2.1vw, 26px);font-weight:400;letter-spacing:0.06em;color:var(--ink-900)">{ev.title}</h2>
                <p class="quote" style="font-size:clamp(15px, 1.3vw, 18px);line-height:1.55;color:var(--ink-700);margin:0;text-wrap:pretty">{ev.blurb}</p>
              </div>
              <div style="margin-top:26px;display:flex;justify-content:flex-end">
                <button type="button" data-poster-open={ev.id} data-variant="on-sage" class="label-track" style="background:transparent;border:1px solid var(--ink-800);color:var(--ink-900);padding:12px 20px;font-size:11px;display:inline-flex;align-items:center;gap:10px">Dettagli evento <Arrow /></button>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section" style="background:var(--ink-800)">
    <div class="container">
      <div class="evt-cta">
        <div>
          <div class="eyebrow" style="color:var(--gold-500);margin-bottom:14px">Iscriviti alla newsletter</div>
          <h2 class="display" style="margin:0;font-size:clamp(20px, 2vw, 26px);letter-spacing:0.08em;font-weight:300">Resta aggiornato sui prossimi appuntamenti.</h2>
        </div>
        <form onsubmit="return false" style="display:flex;gap:8px;flex-wrap:wrap">
          <input type="email" placeholder="email@dominio.it" aria-label="La tua email" style="background:transparent;border:1px solid var(--line-strong);color:var(--cream);padding:14px 18px;min-width:240px;font-size:13px;font-family:inherit;letter-spacing:0.04em" />
          <button type="submit" data-variant="filled" class="label-track" style="background:var(--gold-500);color:var(--ink-900);border:none;padding:14px 22px;font-size:11px">Iscrivimi</button>
        </form>
      </div>
    </div>
  </section>

  <!-- Poster templates -->
  {EVENTS.map((ev, idx) => (
    <template id={`poster-${ev.id}`}>
      <div class="poster-card">
        <div style="height:3px;background:var(--gold-500);flex-shrink:0"></div>
        <div class="poster-body">
          <div style="position:relative;min-height:400px;overflow:hidden">
            <Pattern tone={tones[(idx + 1) % tones.length]} />
            <div style="position:absolute;inset:0;background:linear-gradient(160deg, rgba(29,47,46,0.18) 0%, rgba(29,47,46,0.78) 100%)"></div>
            <div style="position:absolute;inset:0;display:flex;flex-direction:column;justify-content:flex-end;padding:clamp(24px, 3vw, 36px)">
              <div class="eyebrow" style="color:var(--cream);opacity:0.7;margin-bottom:10px;font-size:9px">{ev.kind}</div>
              <div style="font-family:'Cormorant Garamond',serif;font-style:italic;font-size:clamp(36px, 5.5vw, 62px);color:var(--cream);line-height:1;text-shadow:0 2px 20px rgba(0,0,0,0.5)">{ev.dateShort}</div>
              <div style="height:1px;background:var(--gold-500);opacity:0.55;margin:20px 0 18px"></div>
              <span class="brand-mask" style="width:134px;height:16px" role="img" aria-label="Studio Legale Micieli"></span>
            </div>
          </div>
          <div class="poster-right">
            <div style="display:flex;justify-content:flex-end;margin-bottom:20px">
              <button type="button" data-poster-close style="background:transparent;border:1px solid var(--line-strong);color:var(--cream);width:30px;height:30px;display:flex;align-items:center;justify-content:center;cursor:pointer;font-family:inherit;font-size:13px">✕</button>
            </div>
            <div class="eyebrow" style="color:var(--gold-500);margin-bottom:14px;font-size:9px">Locandina</div>
            <h2 class="display" style="margin:0 0 16px;font-size:clamp(16px, 1.6vw, 22px);letter-spacing:0.06em;font-weight:400;line-height:1.35;color:var(--cream)">{ev.title}</h2>
            <p style="margin:0 0 24px;font-size:13.5px;line-height:1.7;opacity:0.78;text-wrap:pretty">{ev.blurb}</p>
            <div style="height:1px;background:var(--line);margin-bottom:22px"></div>
            <div style="margin-bottom:24px">
              <div class="eyebrow" style="color:var(--gold-500);margin-bottom:14px;font-size:9px">Programma</div>
              <div style="display:flex;flex-direction:column;gap:10px">
                {ev.program.map((item) => (
                  <div style="display:flex;gap:12px;font-size:13px;line-height:1.55;opacity:0.85">
                    <span style="color:var(--gold-500);flex-shrink:0">—</span><span>{item}</span>
                  </div>
                ))}
              </div>
            </div>
            <div style="height:1px;background:var(--line);margin-bottom:20px"></div>
            <div style="display:flex;flex-direction:column;gap:10px;font-size:13px">
              <div style="display:flex;gap:16px;align-items:baseline">
                <span class="eyebrow" style="color:var(--gold-500);font-size:8px;min-width:72px">Data</span><span style="opacity:0.85">{ev.date}</span>
              </div>
              <div style="display:flex;gap:16px;align-items:baseline">
                <span class="eyebrow" style="color:var(--gold-500);font-size:8px;min-width:72px">Luogo</span><span style="opacity:0.85">{ev.location}</span>
              </div>
              <div style="display:flex;gap:16px;align-items:baseline">
                <span class="eyebrow" style="color:var(--gold-500);font-size:8px;min-width:72px">Organizzato da</span><span style="opacity:0.85">Studio Legale Micieli</span>
              </div>
            </div>
            <div style="margin-top:auto;padding-top:28px">
              <a href="mailto:studio@studiolegalemicieli.it" style="display:inline-flex;align-items:center;gap:10px;color:var(--gold-500);font-size:11px;letter-spacing:0.18em;text-transform:uppercase;font-weight:500">Contattaci per info <Arrow size={11} /></a>
            </div>
          </div>
        </div>
      </div>
    </template>
  ))}

  <div class="poster-overlay" id="posterOverlay">
    <div data-poster-slot></div>
  </div>
</main>
