---
import { STUDIO } from '../../data';
import type { Policy } from '../../legal';
import Arrow from '../Arrow.astro';

interface Props { policy: Policy; kind: 'privacy' | 'cookie'; }
const { policy, kind } = Astro.props;
const isCookie = kind === 'cookie';
---
<main>
  <section class="section" style="background:var(--ink-800);padding-top:clamp(56px, 7vw, 96px);padding-bottom:clamp(56px, 7vw, 96px)">
    <div class="container">
      <div style="max-width:760px">
        <div class="eyebrow" style="color:var(--gold-500);margin-bottom:18px">{isCookie ? 'Informativa Cookie' : 'Informativa Privacy'}</div>
        <h1 class="display" style="font-size:clamp(28px, 4.4vw, 54px);margin:0;font-weight:300">{policy.title}</h1>
        <p style="margin-top:26px;font-size:clamp(15px, 1.3vw, 17px);line-height:1.7;opacity:0.86;max-width:640px;text-wrap:pretty">{policy.lede}</p>
      </div>
      <div style="margin-top:14px;font-size:12px;letter-spacing:0.16em;text-transform:uppercase;opacity:0.6">Ultimo aggiornamento: {policy.updated}</div>
    </div>
  </section>

  <section class="section" style="background:var(--ink-900);padding-top:clamp(48px, 6vw, 80px);padding-bottom:clamp(48px, 6vw, 80px)">
    <div class="container">
      <div class="legal-wrap">
        <aside class="legal-toc">
          <div class="eyebrow" style="color:var(--gold-500);margin-bottom:14px">Indice</div>
          <ol style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:10px">
            {policy.sections.map((s, i) => (
              <li>
                <a href={`#${s.id}`} style="font-size:13px;opacity:0.78;line-height:1.45">
                  <span style="color:var(--gold-500);margin-right:8px">0{i + 1}</span>{s.title}
                </a>
              </li>
            ))}
          </ol>
          <a href={isCookie ? '/privacy/' : '/cookie/'} class="label-track" style="margin-top:24px;background:transparent;border:1px solid var(--line-strong);color:var(--cream);padding:12px 16px;font-size:10.5px;display:inline-flex;align-items:center;gap:8px">{isCookie ? 'Privacy Policy' : 'Cookie Policy'} <Arrow size={12} /></a>
          <button type="button" data-cookie-settings data-variant="filled" class="label-track" style="margin-top:10px;background:var(--gold-500);border:none;color:var(--ink-900);padding:12px 16px;font-size:10.5px;display:inline-flex;align-items:center;gap:8px;width:100%;justify-content:space-between">Preferenze Cookie <Arrow size={12} /></button>
        </aside>

        <article style="max-width:760px">
          {policy.sections.map((s, i) => (
            <section id={s.id} style="padding-bottom:36px;margin-bottom:36px;border-bottom:1px solid var(--line);scroll-margin-top:96px">
              <div class="eyebrow" style="color:var(--gold-500);margin-bottom:14px">0{i + 1} · Sezione</div>
              <h2 class="display" style="margin:0;font-size:clamp(20px, 2vw, 26px);font-weight:400;letter-spacing:0.08em">{s.title}</h2>
              <div style="margin-top:18px;font-size:15px;line-height:1.8;opacity:0.9;text-wrap:pretty" set:html={s.body}></div>
            </section>
          ))}
          <div style="margin-top:12px;padding:clamp(22px, 2.6vw, 30px);border:1px solid var(--line);background:var(--ink-800)">
            <div class="eyebrow" style="color:var(--gold-500);margin-bottom:12px">Titolare del trattamento</div>
            <p style="margin:0;font-size:14px;line-height:1.7;opacity:0.9">
              Studio Legale Micieli<br />{STUDIO.address}<br />
              <a href={`mailto:${STUDIO.email}`} style="color:var(--gold-500)">{STUDIO.email}</a> · {STUDIO.phone}
            </p>
          </div>
        </article>
      </div>
    </div>
  </section>
</main>
