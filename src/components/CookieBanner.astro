---
import { STUDIO } from '../data';
---
<!-- Cookie consent banner -->
<div class="cookie-banner" id="cookieBanner" role="dialog" aria-label="Preferenze Cookie">
  <div class="cb-wrap">
    <div>
      <div class="eyebrow" style="color:var(--gold-500);margin-bottom:8px">Cookie · Privacy</div>
      <p style="margin:0;font-size:14px;line-height:1.6;max-width:700px">
        Utilizziamo cookie tecnici necessari al funzionamento del sito e, previo consenso, cookie analitici in forma anonima. Nessun cookie di profilazione o marketing.
        <a href={STUDIO.privacyUrl} target="_blank" rel="noopener" style="color:var(--gold-500);text-decoration:underline">Leggi l'informativa estesa</a>.
      </p>
    </div>
    <div class="cb-actions">
      <button type="button" class="label-track" data-cookie-settings style="background:transparent;border:1px solid var(--line-strong);color:var(--cream);padding:12px 16px;font-size:10.5px">Personalizza</button>
      <button type="button" class="label-track" data-cookie-reject style="background:transparent;border:1px solid var(--line-strong);color:var(--cream);padding:12px 16px;font-size:10.5px">Rifiuta</button>
      <button type="button" class="label-track" data-variant="filled" data-cookie-accept style="background:var(--gold-500);border:none;color:var(--ink-900);padding:12px 18px;font-size:10.5px">Accetta</button>
    </div>
  </div>
</div>

<!-- Preferences modal -->
<div class="cookie-modal" id="cookieModal" role="dialog" aria-modal="true" aria-label="Preferenze Cookie">
  <div class="cookie-modal-card" data-modal-card>
    <div class="eyebrow" style="color:var(--gold-500)">Preferenze</div>
    <h2 class="display" style="margin:14px 0 8px;font-size:22px;letter-spacing:0.08em;font-weight:400">Gestisci i cookie</h2>
    <p style="margin:0 0 24px;font-size:13px;opacity:0.8;line-height:1.6">
      Puoi modificare le tue preferenze in qualsiasi momento. I cookie tecnici sono sempre attivi.
    </p>

    <div style="display:flex;flex-direction:column;gap:14px">
      <div style="border:1px solid var(--line);padding:16px 18px;background:var(--ink-800);display:grid;grid-template-columns:1fr auto;gap:16px;align-items:flex-start">
        <div>
          <div style="font-size:13px;font-weight:600;letter-spacing:0.04em">Cookie tecnici necessari</div>
          <p style="margin:6px 0 0;font-size:12.5px;opacity:0.78;line-height:1.55">Indispensabili per il funzionamento del sito (preferenze, sicurezza, sessione).</p>
          <div style="margin-top:8px;font-size:10px;letter-spacing:0.18em;text-transform:uppercase;color:var(--gold-500)">Sempre attivo</div>
        </div>
        <button type="button" class="toggle-switch" role="switch" aria-checked="true" disabled><span class="knob"></span></button>
      </div>
      <div style="border:1px solid var(--line);padding:16px 18px;background:var(--ink-800);display:grid;grid-template-columns:1fr auto;gap:16px;align-items:flex-start">
        <div>
          <div style="font-size:13px;font-weight:600;letter-spacing:0.04em">Cookie analitici anonimi</div>
          <p style="margin:6px 0 0;font-size:12.5px;opacity:0.78;line-height:1.55">Statistiche aggregate sull'uso del sito, con IP anonimizzato. Possono essere disattivati senza compromettere la navigazione.</p>
        </div>
        <button type="button" class="toggle-switch" role="switch" aria-checked="false" data-analytics-toggle><span class="knob"></span></button>
      </div>
    </div>

    <div style="margin-top:26px;display:flex;flex-wrap:wrap;gap:8px;justify-content:space-between">
      <button type="button" class="label-track" data-cookie-cancel style="background:transparent;border:1px solid var(--line-strong);color:var(--cream);padding:12px 16px;font-size:10.5px">Annulla</button>
      <div style="display:flex;gap:8px;flex-wrap:wrap">
        <button type="button" class="label-track" data-cookie-reject style="background:transparent;border:1px solid var(--line-strong);color:var(--cream);padding:12px 16px;font-size:10.5px">Rifiuta tutto</button>
        <button type="button" class="label-track" data-cookie-save style="background:transparent;border:1px solid var(--gold-500);color:var(--gold-500);padding:12px 16px;font-size:10.5px">Salva scelte</button>
        <button type="button" class="label-track" data-variant="filled" data-cookie-accept style="background:var(--gold-500);border:none;color:var(--ink-900);padding:12px 16px;font-size:10.5px">Accetta tutto</button>
      </div>
    </div>
  </div>
</div>
